<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/son">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <TextView
                android:id="@+id/txtCiceklerBaslik"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tüm Çiçeklerimiz"
                android:textColor="@android:color/white"
                android:textSize="24sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:columnCount="2"
                android:alignmentMode="alignMargins"
                app:layout_constraintTop_toBottomOf="@id/txtCiceklerBaslik"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="15dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/sage"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <ImageView
                            android:id="@+id/imgCicek1"
                            android:layout_width="match_parent"
                            android:layout_height="130dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/cicek1" />
                        <TextView
                            android:id="@+id/txtAd1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kırmızı Gül"
                            android:textColor="@android:color/white"
                            android:textStyle="bold"
                            android:layout_marginTop="8dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="450 TL"
                            android:textColor="@color/evergreen" />
                        <Button
                            android:id="@+id/btnSepet1"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:layout_marginTop="10dp"
                            android:text="Sepete Ekle"
                            android:textSize="10sp"
                            android:backgroundTint="@color/white"
                            android:textColor="@android:color/black" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="15dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/sage"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <ImageView
                            android:id="@+id/imgCicek2"
                            android:layout_width="match_parent"
                            android:layout_height="130dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/cicek2" />
                        <TextView
                            android:id="@+id/txtAd2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Beyaz Papatya"
                            android:textColor="@android:color/white"
                            android:textStyle="bold"
                            android:layout_marginTop="8dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="250 TL"
                            android:textColor="@color/evergreen" />
                        <Button
                            android:id="@+id/btnSepet2"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:layout_marginTop="20dp"
                            android:text="Sepete Ekle"
                            android:textSize="10sp"
                            android:backgroundTint="@color/white"
                            android:textColor="@android:color/black" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="15dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/sage"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <ImageView
                            android:id="@+id/imgCicek3"
                            android:layout_width="match_parent"
                            android:layout_height="130dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/cicek3" />
                        <TextView
                            android:id="@+id/txtAd3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Beyaz Papatya"
                            android:textColor="@android:color/white"
                            android:textStyle="bold"
                            android:layout_marginTop="8dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="250 TL"
                            android:textColor="@color/evergreen" />
                        <Button
                            android:id="@+id/btnSepet3"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:layout_marginTop="10dp"
                            android:text="Sepete Ekle"
                            android:textSize="10sp"
                            android:backgroundTint="@color/white"
                            android:textColor="@android:color/black" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="15dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/sage"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <ImageView
                            android:id="@+id/imgCicek5"
                            android:layout_width="match_parent"
                            android:layout_height="130dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/cicek4" />
                        <TextView
                            android:id="@+id/txtAd5"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Beyaz Papatya"
                            android:textColor="@android:color/white"
                            android:textStyle="bold"
                            android:layout_marginTop="8dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="250 TL"
                            android:textColor="@color/evergreen" />
                        <Button
                            android:id="@+id/btnSepet5"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:layout_marginTop="10dp"
                            android:text="Sepete Ekle"
                            android:textSize="10sp"
                            android:backgroundTint="@color/white"
                            android:textColor="@android:color/black" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="15dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/sage"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <ImageView
                            android:id="@+id/imgCicek6"
                            android:layout_width="match_parent"
                            android:layout_height="130dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/cicek5" />
                        <TextView
                            android:id="@+id/txtAd6"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Beyaz Papatya"
                            android:textColor="@android:color/white"
                            android:textStyle="bold"
                            android:layout_marginTop="8dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="250 TL"
                            android:textColor="@color/evergreen" />
                        <Button
                            android:id="@+id/btnSepet6"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:layout_marginTop="10dp"
                            android:text="Sepete Ekle"
                            android:textSize="10sp"
                            android:backgroundTint="@color/white"
                            android:textColor="@android:color/black" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="15dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/sage"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <ImageView
                            android:id="@+id/imgCicek7"
                            android:layout_width="match_parent"
                            android:layout_height="130dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/cicek6" />
                        <TextView
                            android:id="@+id/txtAd7"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Beyaz Papatya"
                            android:textColor="@android:color/white"
                            android:textStyle="bold"
                            android:layout_marginTop="8dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="250 TL"
                            android:textColor="@color/evergreen" />
                        <Button
                            android:id="@+id/btnSepet7"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:layout_marginTop="10dp"
                            android:text="Sepete Ekle"
                            android:textSize="10sp"
                            android:backgroundTint="@color/white"
                            android:textColor="@android:color/black" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="15dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/sage"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <ImageView
                            android:id="@+id/imgCicek4"
                            android:layout_width="match_parent"
                            android:layout_height="130dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/cicek9" />
                        <TextView
                            android:id="@+id/txtAd4"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Beyaz Papatya"
                            android:textColor="@android:color/white"
                            android:textStyle="bold"
                            android:layout_marginTop="8dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="250 TL"
                            android:textColor="@color/evergreen" />
                        <Button
                            android:id="@+id/btnSepet8"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:layout_marginTop="10dp"
                            android:text="Sepete Ekle"
                            android:textSize="10sp"
                            android:backgroundTint="@color/white"
                            android:textColor="@android:color/black" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </GridLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:background="@drawable/shapes2"
        app:tabTextColor="@android:color/white"
        app:tabSelectedTextColor="#FFD700"
        app:tabIndicatorGravity="top"
        app:tabIndicatorColor="#FFD700"
        app:tabMode="fixed"/>

</LinearLayout>