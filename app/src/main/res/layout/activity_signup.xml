<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/son"
    android:fillViewport="true"
    tools:context=".SignupActivity">

    <!-- Yarı şeffaf karartma overlay -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#55000000" />

        <androidx.cardview.widget.CardView
            android:id="@+id/mainCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginVertical="32dp"
            app:cardBackgroundColor="#FBFBFB"
            app:cardCornerRadius="28dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="28dp"
                android:paddingTop="36dp"
                android:paddingBottom="32dp"
                android:background="@drawable/son">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="KAYIT OL"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hesap oluştur"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#ffff"
                    android:layout_marginBottom="28dp" />

                <!-- Kullanıcı Adı -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kullanıcı Adı"
                    android:textSize="13sp"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/username"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/shapes3"
                    android:gravity="center_vertical"
                    android:hint="Kullanıcı adınız"
                    android:padding="14dp"
                    android:textColorHint="@color/evergreen"
                    android:textSize="15sp"
                    android:inputType="text" />

                <!-- Doğum Tarihi -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Doğum Tarihi"
                    android:textSize="13sp"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/bday"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/shapes3"
                    android:gravity="center_vertical"
                    android:hint="Gün/Ay/Yıl"
                    android:padding="14dp"
                    android:textColorHint="@color/evergreen"
                    android:textSize="15sp"
                    android:focusable="true"
                    android:clickable="true"
                    android:inputType="none" />

                <!-- E-posta -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="E-posta"
                    android:textSize="13sp"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/gmail"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/shapes3"
                    android:gravity="center_vertical"
                    android:hint="E-posta adresiniz"
                    android:padding="14dp"
                    android:textColorHint="@color/evergreen"
                    android:textSize="15sp"
                    android:inputType="textEmailAddress" />

                <!-- Şifre -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Şifre"
                    android:textSize="13sp"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/password"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="28dp"
                    android:background="@drawable/shapes3"
                    android:gravity="center_vertical"
                    android:hint="Şifreniz"
                    android:padding="14dp"
                    android:textColorHint="@color/evergreen"
                    android:textSize="15sp"
                    android:inputType="textPassword" />

                <!-- Kayıt Ol Butonu -->
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_signup"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="20dp"
                    android:background="@drawable/shapes4"
                    android:text="KAYIT OL"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:elevation="4dp" />

                <!-- Ayırıcı -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#DDDDDD" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  veya  "
                        android:textSize="13sp"
                        android:textColor="#ffff" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#DDDDDD" />
                </LinearLayout>

                <!-- Google ile Devam Et -->
                <LinearLayout
                    android:id="@+id/google_logo"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="28dp"
                    android:background="@drawable/shapes"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/google_logo"
                        android:contentDescription="Google Logo" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="Google ile devam et"
                        android:textSize="15sp"
                        android:textColor="@color/evergreen"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Giriş Yap Linki -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Zaten hesabın var mı? "
                        android:textSize="14sp"
                        android:textColor="#ffff" />

                    <TextView
                        android:id="@+id/txt_login"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Giriş Yap"
                        android:textSize="14sp"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </FrameLayout>
</ScrollView>
